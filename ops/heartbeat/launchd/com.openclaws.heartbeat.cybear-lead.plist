<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.openclaws.heartbeat.cybear-lead</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__REPO_ROOT__/scripts/heartbeat/run_lead_heartbeat.sh</string>
    <string>--agent-id</string>
    <string>cybear-lead</string>
    <string>--source</string>
    <string>launchd</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__REPO_ROOT__</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>OPENCLAWS_HEARTBEAT_REPO_ROOT</key>
    <string>__REPO_ROOT__</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>600</integer>
  <key>StandardOutPath</key>
  <string>__REPO_ROOT__/var/heartbeat/logs/launchd-cybear-lead.log</string>
  <key>StandardErrorPath</key>
  <string>__REPO_ROOT__/var/heartbeat/logs/launchd-cybear-lead.log</string>
</dict>
</plist>
